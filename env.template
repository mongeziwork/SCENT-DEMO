# Copy to `.env.local` for development. On Vercel, set Production and Preview
# env vars as needed (Preview often needs the same Supabase keys for testing deploys).

# Supabase (Settings → API in the collaborator’s project)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only; never expose to the browser bundle.
SUPABASE_SERVICE_ROLE_KEY=

# Admin allowlist (comma-separated). Matches `lib/admin-config.ts`.
NEXT_PUBLIC_ADMIN_EMAILS=

# Site URL for absolute links in server routes (e.g. PayFast callbacks)
NEXT_PUBLIC_SITE_URL=

# PayFast (if used)
PAYFAST_MODE=live
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
