NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

PAYFAST_MODE=live
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=

# Used for building absolute return/cancel/notify URLs in server routes.
NEXT_PUBLIC_SITE_URL=

# Lock down /admin to a single email address (case-insensitive).
# Example: you@domain.com
NEXT_PUBLIC_ADMIN_EMAIL=

# Contact form (Web3Forms — https://web3forms.com): create a free access key with your inbox email.
# Public key is safe to expose in the browser; messages go to the email you used when creating the key.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=

