NEXT_PUBLIC_SUPABASE_URL=
# Publishable/anon key (Supabase → API). Same value if you named it NEXT_PUBLIC_SUPABASE_KEY on Vercel.
NEXT_PUBLIC_SUPABASE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only; never expose to the client. Use in Route Handlers / server code that must bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated admin emails (case-insensitive). Used for /admin gate + post-login routing.
NEXT_PUBLIC_ADMIN_EMAILS=

PAYFAST_MODE=live
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=

# Used for building absolute return/cancel/notify URLs in server routes.
NEXT_PUBLIC_SITE_URL=

# Lock down /admin to a single email (case-insensitive). Merged with NEXT_PUBLIC_ADMIN_EMAILS if both set.
# Example: you@domain.com
NEXT_PUBLIC_ADMIN_EMAIL=

# Contact form → sends via Resend (https://resend.com). Messages arrive at scentclobrand@gmail.com by default.
RESEND_API_KEY=
# Verified sender in Resend, e.g. SCENT <contact@yourdomain.com>
CONTACT_FROM_EMAIL=
# Optional override for the inbox (defaults to scentclobrand@gmail.com)
# CONTACT_TO_EMAIL=
