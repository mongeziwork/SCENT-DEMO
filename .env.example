NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

PAYFAST_MODE=live
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=

# Used for building absolute return/cancel/notify URLs in server routes.
NEXT_PUBLIC_SITE_URL=

# Lock down /admin to a single email address (case-insensitive).
# Example: you@domain.com
NEXT_PUBLIC_ADMIN_EMAIL=

# Separate admin portal login password (server-only).
# Set this in Vercel (do NOT expose as NEXT_PUBLIC_).
PORTAL_PASSWORD=

# HMAC secret for portal session cookie signing (server-only).
# Generate a long random string.
PORTAL_COOKIE_SECRET=

